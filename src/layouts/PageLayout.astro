---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  path: string;
  eyebrow: string;
  heading: string;
  lede?: string;
}

const { title, description, path, eyebrow, heading, lede } = Astro.props;
---

<BaseLayout title={title} description={description} path={path}>
  <article class="container-prose pt-20 pb-12 md:pt-28 md:pb-16">
    <header class="mb-8 md:mb-14">
      <div
        class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-ink-5)] mb-5 md:mb-6"
        data-reveal
      >
        {eyebrow}
      </div>
      <h1
        class="font-display text-[clamp(2rem,7vw,4.5rem)] font-semibold leading-[1.05] tracking-tight text-[var(--color-ink)]"
        data-reveal
        data-reveal-delay="80"
      >
        {heading}
      </h1>
      {
        lede && (
          <p
            class="mt-5 md:mt-6 max-w-2xl text-base md:text-xl text-[var(--color-ink-3)] leading-relaxed"
            data-reveal
            data-reveal-delay="160"
          >
            {lede}
          </p>
        )
      }
    </header>

    <div data-reveal data-reveal-delay="240">
      <slot />
    </div>
  </article>
</BaseLayout>
