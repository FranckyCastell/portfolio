---
import PageLayout from "@layouts/PageLayout.astro";
import { projects } from "@data/projects";

const title = "Projects — Francesc Castell";
const description =
  "Selected projects: CloudIA, AgentForge, Homer CLI, AWS architectures, and self-hosted LLMOps infrastructure.";

const statusMap = {
  shipped: { label: "Shipped", color: "text-[var(--color-positive)]" },
  active: { label: "Active", color: "text-[var(--color-accent)]" },
  exploration: { label: "Exploration", color: "text-[var(--color-ink-4)]" },
};

const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
---

<PageLayout
  title={title}
  description={description}
  path="/projects"
  eyebrow="— PROJECTS"
  heading="Tools and systems I've built."
  lede="From internal CLIs that save hours every week to self-hosted AI infrastructure. Each project started as a real frustration I wanted to make disappear."
>
  <div class="space-y-10">
    {
      featured.map((p, i) => (
        <article
          class="group relative rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 sm:p-8 transition duration-300 hover:border-[var(--color-border-strong)] hover:shadow-lg hover:-translate-y-0.5"
          data-reveal
          data-reveal-delay={String(i * 80)}
        >
          <div class="flex items-start justify-between gap-4 mb-3">
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-[var(--color-accent)] font-medium">{`0${i + 1}`}</span>
              <span class={`font-mono text-[11px] uppercase tracking-wider px-2 py-0.5 rounded-sm ${p.status === 'active' ? 'bg-[var(--color-accent)]/15 text-[var(--color-accent)]' : 'bg-[var(--color-surface-2)] text-[var(--color-ink-4)]'}`}>
                {statusMap[p.status].label}
              </span>
            </div>
            <div class="font-mono text-xs text-[var(--color-ink-5)] tabular-nums">{p.year}</div>
          </div>

          <h2 class="text-xl sm:text-2xl font-semibold text-[var(--color-ink)] transition-colors duration-200 group-hover:text-[var(--color-accent-2)]">
            {p.name}
          </h2>
          <p class="mt-1 text-sm text-[var(--color-ink-4)]">{p.tagline}</p>

          <p class="mt-5 text-sm sm:text-base text-[var(--color-ink-2)] leading-relaxed">
            {p.description}
          </p>

          {p.highlights && p.highlights.length > 0 && (
            <ul class="mt-5 space-y-2">
              {p.highlights.map((h) => (
                <li class="flex gap-2.5 text-sm text-[var(--color-ink-3)] leading-relaxed">
                  <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5">→</span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          )}

          <div class="mt-6 pt-5 border-t border-[var(--color-border)] flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap gap-1.5">
              {p.tags.map((tag) => (
                <span class="rounded-sm border border-[var(--color-border)] bg-[var(--color-surface-2)] px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-[var(--color-ink-4)]">
                  {tag}
                </span>
              ))}
            </div>
            {p.links && p.links.length > 0 && (
              <div class="flex items-center gap-2 flex-shrink-0">
                {p.links.map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 rounded-md border border-[var(--color-border)] bg-[var(--color-surface-2)] px-3 py-1.5 font-mono text-xs text-[var(--color-ink-3)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
                  >
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                    </svg>
                    {link.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        </article>
      ))
    }

    {
      rest.length > 0 && (
        <div>
          <div class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--color-ink-5)] mb-6" data-reveal>
            — Also built
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {rest.map((p, i) => (
              <article
                class="group relative flex rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition duration-200 hover:border-[var(--color-border-strong)] hover:bg-[var(--color-surface-2)] hover:-translate-y-0.5"
                data-reveal
                data-reveal-delay={String(i * 60)}
              >
                <div>
                  <div class="flex items-baseline gap-2 mb-1">
                    <h3 class="text-sm font-semibold text-[var(--color-ink)] transition-colors group-hover:text-[var(--color-accent-2)]">
                      {p.name}
                    </h3>
                    <span class={`font-mono text-[10px] uppercase tracking-wider ${statusMap[p.status].color}`}>
                      {statusMap[p.status].label}
                    </span>
                  </div>
                  <p class="text-xs text-[var(--color-ink-4)] line-clamp-2">{p.tagline}</p>
                </div>
                <div class="mt-4 flex items-center justify-between gap-3">
                  <div class="flex flex-wrap gap-1">
                    {p.tags.slice(0, 3).map((tag) => (
                      <span class="rounded-sm border border-[var(--color-border)] bg-[var(--color-surface-2)] px-1.5 py-0.5 font-mono text-[9px] uppercase tracking-wider text-[var(--color-ink-5)]">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <div class="flex items-center gap-3 flex-shrink-0">
                    <span class="font-mono text-[10px] text-[var(--color-ink-5)] tabular-nums">{p.year}</span>
                    {p.links?.map((link) => (
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface-2)] px-2 py-1 font-mono text-[10px] text-[var(--color-ink-3)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] flex items-center gap-1"
                      >
                        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                        </svg>
                        Code
                      </a>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      )
    }
  </div>
</PageLayout>
