---
import { navItems, social } from "@data/site";

const year = new Date().getFullYear();
const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname.startsWith(href);
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)]">
  <div class="container-wide py-12 md:py-16">
    <div class="grid gap-8 md:grid-cols-[1.4fr_1fr_1fr] md:gap-10">
      <div class="space-y-3">
        <div class="font-mono text-xs tracking-[0.18em] text-[var(--color-ink-4)]">
          FRANCESC&nbsp;CASTELL
        </div>
        <p class="max-w-md text-sm text-[var(--color-ink-3)] leading-relaxed">
          DevOps engineer building secure, automated AWS infrastructure and exploring
          the infrastructure layer of LLMOps. Open to selected consulting engagements.
        </p>
        <p class="font-mono text-xs text-[var(--color-ink-5)]">
          {social.location} · UTC+1
        </p>
      </div>

      <nav class="space-y-2" aria-label="Footer sections">
        <div class="mono-label mb-3">Sitemap</div>
        <a
          href="/"
          class={`block text-sm transition-colors duration-200 hover:text-[var(--color-ink)] ${
            pathname === "/" ? "text-[var(--color-ink)]" : "text-[var(--color-ink-3)]"
          }`}
        >
          Home
        </a>
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class={`block text-sm transition-colors duration-200 hover:text-[var(--color-ink)] ${
                isActive(item.href) ? "text-[var(--color-ink)]" : "text-[var(--color-ink-3)]"
              }`}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="space-y-2">
        <div class="mono-label mb-3">Elsewhere</div>
        <a
          href={social.github}
          target="_blank"
          rel="noopener noreferrer"
          class="block text-sm text-[var(--color-ink-3)] transition-colors duration-200 hover:text-[var(--color-ink)]"
        >
          GitHub ↗
        </a>
        <a
          href={social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="block text-sm text-[var(--color-ink-3)] transition-colors duration-200 hover:text-[var(--color-ink)]"
        >
          LinkedIn ↗
        </a>
        <a
          href={`mailto:${social.email}`}
          class="block text-sm text-[var(--color-ink-3)] transition-colors duration-200 hover:text-[var(--color-ink)]"
        >
          {social.email}
        </a>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-[var(--color-border)] pt-6 text-xs text-[var(--color-ink-5)] sm:flex-row sm:items-center"
    >
      <div class="font-mono">
        © {year} Francesc Castell
      </div>
      <div class="font-mono">
        <span class="cursor-blink"></span>
      </div>
    </div>
  </div>
</footer>
